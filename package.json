{
  "name": "matilha-builders",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @matilha-builders/db",
    "db:studio": "turbo run db:studio -F @matilha-builders/db",
    "db:generate": "turbo run db:generate -F @matilha-builders/db",
    "db:migrate": "turbo run db:migrate -F @matilha-builders/db",
    "deploy:setup": "vercel link",
    "dev:vercel": "vercel dev -L",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@matilha-builders/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@matilha-builders/config": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "ultracite": "7.9.3",
    "vercel": "^54.18.6"
  },
  "packageManager": "pnpm@10.33.0"
}
